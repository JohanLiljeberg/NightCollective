@model IReadOnlyCollection<Night.Models.CollectiveMember>
@{
    ViewData["Title"] = "Collective Members";
}

<section class="mb-5" aria-labelledby="members-heading">
    <div class="d-flex flex-column flex-lg-row align-items-lg-end justify-content-between gap-3 mb-4">
        <div>
            <p class="eyebrow mb-1">The collective</p>
            <h1 id="members-heading" class="display-5 fw-bold mb-2">Collective members</h1>
            <p class="lead mb-0">Meet the people making, publishing, and celebrating games as art.</p>
        </div>
        <a class="btn btn-primary" asp-controller="Home" asp-action="Index">Back to home</a>
    </div>

    <div class="row g-4">
        @foreach (var member in Model)
        {
            <div class="col-md-6 col-xl-4">
                @await Component.InvokeAsync("CollectiveMemberVC", new { member })
            </div>
        }
    </div>
</section>
